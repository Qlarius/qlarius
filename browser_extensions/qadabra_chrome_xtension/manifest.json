{
  "manifest_version": 3,
  "name": "Qadabra",
  "version": "1.3.4",
  "description": "Qadabra browser extension — wallet, ads, and silent sign-in across publisher widgets.",
  "permissions": [
    "notifications",
    "activeTab",
    "storage",
    "scripting",
    "webNavigation"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "toggle-env-ui": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Toggle Qadabra Local/Prod switcher in the popup"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://qadabra.app/*",
        "https://*.qadabra.app/*",
        "https://qlinkin.bio/*",
        "https://www.qlinkin.bio/*",
        "https://qlarius.gigalixirapp.com/*",
        "https://*.gigalixirapp.com/*",
        "http://localhost:4000/*",
        "http://localhost:4001/*",
        "https://localhost:4001/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://qadabra.app/*",
      "https://*.qadabra.app/*",
      "https://qlinkin.bio/*",
      "https://www.qlinkin.bio/*",
      "https://qlarius.gigalixirapp.com/*",
      "https://*.gigalixirapp.com/*",
      "http://localhost:4000/*",
      "http://localhost:4001/*",
      "https://localhost:4001/*"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://qadabra.app https://*.qadabra.app https://qlarius.gigalixirapp.com https://localhost:4001 http://localhost:4001 http://localhost:4000; connect-src 'self' https://qadabra.app https://*.qadabra.app https://qlinkin.bio https://www.qlinkin.bio wss://qadabra.app wss://*.qadabra.app https://qlarius.gigalixirapp.com wss://qlarius.gigalixirapp.com https://localhost:4001 wss://localhost:4001 http://localhost:4001 http://localhost:4000 ws://localhost:4000 ws://localhost:4001"
  },
  "host_permissions": [
    "https://qadabra.app/*",
    "https://*.qadabra.app/*",
    "https://qlinkin.bio/*",
    "https://www.qlinkin.bio/*",
    "https://qlarius.gigalixirapp.com/*",
    "https://*.gigalixirapp.com/*",
    "http://localhost:4000/*",
    "http://localhost:4001/*",
    "https://localhost:4001/*"
  ]
}
