elixir_version=1.18.3
erlang_version=27.0

# Build and digest JS/CSS on every Gigalixir deploy (priv/static/assets is not in git).
# npm ci installs @floating-ui/dom (see assets/package.json); node_modules is not in git.
hook_post_compile="cd assets && npm ci --omit=dev && cd .. && mix assets.deploy && rm -f _build/esbuild*"
