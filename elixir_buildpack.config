elixir_version=1.18.3
erlang_version=27.0

# Build and digest JS/CSS on every Gigalixir deploy (priv/static/assets is not in git).
# hook must use eval — the buildpack invokes $hook_post_compile without a shell (word-split breaks cd/&&).
# npm ci installs @floating-ui/dom (see assets/package.json); node_modules is not in git.
hook_post_compile="eval \"npm --prefix assets ci --omit=dev && mix assets.deploy && rm -f _build/esbuild*\""
