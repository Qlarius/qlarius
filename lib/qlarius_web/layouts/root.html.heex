<!DOCTYPE html>
<html
  lang="en"
  class="[scrollbar-gutter:stable]"
>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, viewport-fit=cover"
    />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f3f4f6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1f2937" media="(prefers-color-scheme: dark)" />
    <meta name="application-name" content="Qadabra" />
    <meta name="apple-mobile-web-app-title" content="Qadabra" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="icon" type="image/png" href="/images/favicon.png" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/qlarius_app_icon_180.png" />
    <%!-- Manifest link is added dynamically by JavaScript with referral code --%>
    <%!-- Omit live_title `default` so a missing join `t` does not overwrite SSR title. --%>
    <.live_title>
      {assigns[:page_title] || "Qadabra"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        // Referral code sharing via Cache Storage (works across Safari <-> PWA on iOS)
        const REFERRAL_ENDPOINT = '/_shared/referral-code';
        
        const refParams = new URLSearchParams(window.location.search);
        const refCodeFromUrl = refParams.get('ref') || refParams.get('invite');
        
        // If we have a ref code from URL, store it everywhere
        if (refCodeFromUrl) {
          // Store in localStorage (works within same context)
          try { localStorage.setItem('qadabra_referral_code', refCodeFromUrl); } catch (e) {}
          
          // Store in Cache Storage via service worker (SHARED between Safari and PWA on iOS!)
          if ('serviceWorker' in navigator) {
            navigator.serviceWorker.ready.then(() => {
              fetch(REFERRAL_ENDPOINT, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ referral_code: refCodeFromUrl })
              }).then(() => {
                console.log('🎯 Referral code saved to shared Cache Storage:', refCodeFromUrl);
              }).catch(e => console.warn('Failed to save referral to cache:', e));
            });
          }
        }
        
        // Try to read referral code from Cache Storage (for PWA opening without URL params)
        if ('serviceWorker' in navigator) {
          navigator.serviceWorker.ready.then(() => {
            fetch(REFERRAL_ENDPOINT).then(r => r.json()).then(data => {
              if (data.referral_code) {
                console.log('🎯 Referral code loaded from shared Cache Storage:', data.referral_code);
                // Store to localStorage so our hooks can find it
                try { localStorage.setItem('qadabra_referral_code', data.referral_code); } catch (e) {}
                // Dispatch event for any listeners
                window.dispatchEvent(new CustomEvent('referral-code-loaded', { detail: data.referral_code }));
              }
            }).catch(() => {});
          });
        }
        
        const updateThemeColor = (isDark) => {
          const themeColor = isDark ? "#1f2937" : "#f3f4f6";
          let metaTag = document.querySelector('meta[name="theme-color"]:not([media])');
          if (!metaTag) {
            metaTag = document.createElement('meta');
            metaTag.setAttribute('name', 'theme-color');
            document.head.appendChild(metaTag);
          }
          metaTag.setAttribute('content', themeColor);
        };

        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.setItem("phx:theme", "system");
            const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            document.documentElement.setAttribute("data-theme", systemPrefersDark ? "dark" : "light");
            document.documentElement.setAttribute("data-theme-mode", "system");
            updateThemeColor(systemPrefersDark);
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
            document.documentElement.setAttribute("data-theme-mode", theme);
            updateThemeColor(theme === "dark");
          }
        };

        // Public Qlink page (`/@:alias` on qlink/localhost/qlinkin, etc.): always light <html> theme,
        // independent of `phx:theme`, system appearance, and `?force_theme=`.
        const isQlinkPublicPath = (pathname) => pathname.startsWith("/@");

        const applyThemeForCurrentPath = () => {
          if (isQlinkPublicPath(window.location.pathname)) {
            document.documentElement.setAttribute("data-theme", "light");
            document.documentElement.setAttribute("data-theme-mode", "qlink");
            updateThemeColor(false);
            return;
          }
          const sp = new URLSearchParams(window.location.search);
          const forceT = sp.get("force_theme");
          if (forceT) {
            document.documentElement.setAttribute("data-theme", forceT);
            document.documentElement.setAttribute("data-theme-mode", "forced");
            updateThemeColor(forceT === "dark");
            return;
          }
          const initial =
            sp.get("theme") || localStorage.getItem("phx:theme") || "system";
          setTheme(initial);
        };

        applyThemeForCurrentPath();

        const sp0 = new URLSearchParams(window.location.search);
        if (!sp0.get("force_theme")) {
          window.addEventListener("storage", (e) => {
            if (e.key !== "phx:theme" || isQlinkPublicPath(window.location.pathname))
              return;
            setTheme(e.newValue || "system");
          });
          window.addEventListener("phx:set-theme", ({ detail: { theme } }) => {
            if (isQlinkPublicPath(window.location.pathname)) return;
            setTheme(theme);
          });
          window
            .matchMedia("(prefers-color-scheme: dark)")
            .addEventListener("change", () => {
              if (isQlinkPublicPath(window.location.pathname)) return;
              const current = localStorage.getItem("phx:theme");
              if (!current || current === "system") setTheme("system");
            });
        }

        window.addEventListener("phx:page-loading-stop", applyThemeForCurrentPath);
      })();

      (() => {
        const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
        const isPWA =
          window.matchMedia("(display-mode: standalone)").matches ||
          window.navigator.standalone === true;

        if (!isPWA || !isIOS) return;

        const setAppHeight = () => {
          document.documentElement.style.setProperty("--app-height", `${window.innerHeight}px`);
        };

        const measureSafeTop = () => {
          const probe = document.createElement("div");
          probe.style.cssText =
            "position:fixed;top:0;left:0;visibility:hidden;pointer-events:none;padding-top:env(safe-area-inset-top);";
          document.documentElement.appendChild(probe);
          let top = parseFloat(getComputedStyle(probe).paddingTop) || 0;
          probe.remove();
          top = Math.min(Math.max(top, 0), 59);
          document.documentElement.style.setProperty("--pwa-safe-area-top", `${top}px`);
        };

        setAppHeight();
        measureSafeTop();
        window.addEventListener("resize", setAppHeight);
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
